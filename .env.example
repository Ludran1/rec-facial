SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# Modelo de reconocimiento facial (Facenet512 recomendado)
FACE_MODEL=Facenet512

# Umbral de similitud (0.0 - 1.0, menor = más estricto)
# Facenet512 default: 0.30
FACE_THRESHOLD=0.30

# Detector de rostros (retinaface es el más preciso, opencv es el más rápido)
FACE_DETECTOR=retinaface

# Puerto del servidor
PORT=8000

# CORS origins (separados por coma)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://tu-dominio.com
