SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# Modelo de reconocimiento facial (ArcFace recomendado con InsightFace)
FACE_MODEL=ArcFace

# Umbral de similitud (0.0 - 1.0, menor = más estricto)
# ArcFace cosine recomendado: 0.45
FACE_THRESHOLD=0.45

# Detector de rostros (retinaface es el más preciso)
FACE_DETECTOR=retinaface

# Anti-spoofing: detectar fotos en lugar de personas reales (true/false)
# Análisis de nitidez, color y reflejos. Sin nuevos modelos.
ANTISPOOFING_ENABLED=true

# Puerto del servidor
PORT=8000

# CORS origins (separados por coma)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://tu-dominio.com
